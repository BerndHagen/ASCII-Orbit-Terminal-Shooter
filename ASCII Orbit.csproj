<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>AsciiOrbit</RootNamespace>
    <AssemblyName>ASCII Orbit</AssemblyName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <InvariantGlobalization>true</InvariantGlobalization>

    <Version>1.1.0</Version>
    <Authors>Bernd Hagen</Authors>
    <Company>Bernd Hagen</Company>
    <Product>ASCII Orbit</Product>
    <AssemblyTitle>ASCII Orbit</AssemblyTitle>
    <Description>ASCII Orbit — a cross-platform retro terminal shooter where you defend against descending alphabetical invaders.</Description>
    <Copyright>Copyright © 2024-2026 Bernd Hagen</Copyright>
  </PropertyGroup>

</Project>
